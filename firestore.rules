rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Secure helper to verify if the user is the authorized admin
    function isAdmin() {
      return request.auth != null && 'email' in request.auth.token && request.auth.token.email == 'hasanfreefireid0077@gmail.com';
    }

    match /users/{uid} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == uid);
    }
    
    match /device_tokens/{deviceToken} {
      allow get: if true;
      allow list: if false;
      allow write: if request.auth != null;
    }
    
    match /withdraw_requests/{requestId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow write: if isAdmin() || (request.auth != null && request.resource.data.uid == request.auth.uid);
    }
    
    match /conversions/{conversionId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow write: if isAdmin() || (request.auth != null && request.resource.data.uid == request.auth.uid);
    }
    
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
